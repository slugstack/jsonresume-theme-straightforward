{{#if resume.work.length}}
  <div id="work-block" class="section-block">
    <div class="section-intro">
      <div class="section-name">
        <span>Experience</span>
      </div>
      <div class="section-intro-line"></div>
    </div>
    <div class="section-content">
      {{#each resume.work}}
        <div class="job-block">
          <div class="block-header">
            <span class="title">{{position}}</span>
            <span class="date">
              <time datetime="{{startDate}}">{{MONTH_YEAR startDate}}</time> &mdash;
              {{#if endDate}}<time datetime="{{endDate}}">{{MONTH_YEAR endDate}}</time>{{else}}Present{{/if}}
            </span>
          </div>

          <div class="job-meta">{{name}}{{#if location}}, {{location}}{{/if}}</div>

          <div class="display-none">
            {{!-- hidden for now; left here in case we want to make it visible in the future --}}
            {{#if website}}
              <span class="website"><a href="{{website}}">{{website}}</a></span>
            {{/if}}
          </div>

          {{#if summary}}
            <div class="job-summary">{{summary}}</div>
          {{/if}}

          {{#if highlights.length}}
            <ul class="highlights">
              {{#each highlights}}
                <li>{{.}}</li>
              {{/each}}
            </ul>
          {{/if}}
          {{#unless @last}}
            <div class="separator"></div>
          {{/unless}}
        </div>
      {{/each}}
    </div>
  </div>
  <div class="section-line"></div>
{{/if}}
